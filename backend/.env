# Cognee's own internal extraction (turning text into graph entities/relationships)
# — routed through Ollama's Mistral, no OpenAI key needed.
LLM_PROVIDER=ollama
LLM_MODEL=mistral
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama

# Nova's actual chat replies (what the customer sees)
CHAT_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Embeddings — required for Cognee's vector/graph search to work at all.
# Also routed through Ollama, using a small dedicated embedding model.
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=768
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5
ENABLE_BACKEND_ACCESS_CONTROL=false
# Optional: point at a self-hosted Postgres/Neo4j instead of the local default (SQLite/NetworkX/LanceDB)
# See https://docs.cognee.ai for the full list of supported backends.
